# Git metadata
.git
.gitignore

# Local Terraform artifacts
**/.terraform
**/.terraform/*
**/*.tfstate
**/*.tfstate.*
**/*.tfvars
**/*.tfvars.json
**/.terraform.lock.hcl
**/tfplan

# Local environment files
.env
.env.*

# IDE and OS files
.vscode
.idea
.DS_Store
Thumbs.db

# Draw.io temporary backups
.$*.drawio.bkp
~$*

# Repository content not required by the current Dockerfile
# The image only needs scripts/runner/ and config/ — exclude everything else.
README.md
Dockerfile
ci/
docs/
lambdas/
terraform/
tests/
