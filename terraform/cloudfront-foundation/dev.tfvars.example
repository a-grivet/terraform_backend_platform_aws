# cloudfront-foundation — dev environment example
#
# Copy this file to dev.tfvars and fill in the values marked <...>.
# This file is committed; dev.tfvars is gitignored.
#
# CI selects this stack with:
#   terraform plan -var-file=dev.tfvars
#
# The stack provisions:
#   - A CloudFront distribution fronting the upload and deployment APIs
#   - A WAF WebACL in us-east-1 (CloudFront WAF must always be in us-east-1)
#     with geo-blocking, rate limiting, and optional IP allowlist
#
# Prerequisites: upload-foundation and deployment-foundation must be applied first.
# This stack reads their Terraform remote state to derive the API Gateway IDs.

aws_region  = "eu-west-3"
environment = "dev"

# ── Remote state ────────────────────────────────────────────────────────────────
# S3 bucket and state keys must match backend-dev.hcl.
# The bucket name follows the convention: inca-terraform-state-<AWS_ACCOUNT_ID>.

terraform_state_bucket          = "inca-terraform-state-<YOUR_AWS_ACCOUNT_ID>"
upload_foundation_state_key     = "platform/upload-foundation/dev/terraform.tfstate"
deployment_foundation_state_key = "platform/deployment-foundation/dev/terraform.tfstate"

# ── CloudFront WAF ──────────────────────────────────────────────────────────────
# Same semantics as waf-foundation but scoped to CloudFront (us-east-1).
# Requests from countries NOT listed are blocked at the CloudFront edge.

allowed_country_codes = ["FR"]
rate_limit_per_ip     = 100

# CIDR ranges that bypass all WAF rules.
# Add the GitLab CI runner IP so smoke tests reach the API through CloudFront.
# Find the runner IP in the CI job log: "Running on runner-... via <IP>".

ip_allowlist = ["<CI_RUNNER_IP>/32"]

cloudwatch_log_retention_days = 90

tags = {
  managed_by  = "terraform"
  project     = "inca-auto-deployer"
  component   = "cloudfront-foundation"
  environment = "dev"
}
